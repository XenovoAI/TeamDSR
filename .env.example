# ===========================================
# NEETPEAK ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in your values
# ===========================================

# ============ SUPABASE (Client-side) ============
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============ FIREBASE (Client-side) ============
# Values below are based on your Firebase web app setup.
# Replace the placeholders with the remaining values from Firebase console.
VITE_FIREBASE_API_KEY=AIzaSyDhyBUZmfQ-EJXWraYQN6gLkq7HdGdBbeg
VITE_FIREBASE_AUTH_DOMAIN=smneetapp.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://smneetapp-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=smneetapp
VITE_FIREBASE_STORAGE_BUCKET=smneetapp.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=258042156149
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
# ReCAPTCHA v3 site key for App Check (get from Firebase Console > App Check)
VITE_FIREBASE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ============ SUPABASE (Server-side) ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ============ RAZORPAY (Payment Gateway) ============
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============ SHIPROCKET (Shipping) ============
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_PICKUP_LOCATION=your_pickup_location_name
SHIPROCKET_PICKUP_PINCODE=your_pickup_pincode

# ============ NODE ENVIRONMENT ============
NODE_ENV=development
